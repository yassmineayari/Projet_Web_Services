              "path": ["traffic", "zones", "congested"]
            }
          }
        },
        {
          "name": "Update Zone Density",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\\n  \\\"vehicleCount\\\": 85,\\n  \\\"averageSpeed\\\": 8.5\\n}"
            },
            "url": {
              "raw": "{{traffic_url}}/traffic/zones/{{zone_id}}/density",
              "host": ["{{traffic_url}}"],
              "path": ["traffic", "zones", "{{zone_id}}", "density"]
            }
          }
        },
        {
          "name": "Delete Traffic Zone",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{traffic_url}}/traffic/zones/{{zone_id}}",
              "host": ["{{traffic_url}}"],
              "path": ["traffic", "zones", "{{zone_id}}"]
            }
          }
        }
      ]
    },
    {
