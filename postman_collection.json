      "name": "1. Authentication Service",
      "item": [
        {
          "name": "1.1 Register ADMIN",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const jsonData = pm.response.json();",
                  "const token = jsonData?.data?.register?.accessToken;",
                  "if (token) {",
                  "    pm.collectionVariables.set('admin_token', token);",
                  "    console.log('✅ Admin token saved');",
                  "}",
                  "const userId = jsonData?.data?.register?.user?.id;",
                  "if (userId) pm.collectionVariables.set('user_id', userId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation RegisterUser($email: String!, $password: String!, $firstName: String!, $lastName: String!, $role: String!) { register(email: $email, password: $password, firstName: $firstName, lastName: $lastName, role: $role) { accessToken refreshToken expiresIn user { id email firstName lastName role isActive } } }\",\n  \"variables\": {\n    \"email\": \"admin@traffic.com\",\n    \"password\": \"Admin123!\",\n    \"firstName\": \"Super\",\n    \"lastName\": \"Admin\",\n    \"role\": \"ADMIN\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/graphql",
              "host": ["{{base_url}}"],
              "path": ["graphql"]
            }
          }
        },
