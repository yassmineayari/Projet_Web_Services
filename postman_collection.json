{
  "info": {
    "name": "Urban Traffic Management System - REST API",
    "description": "Complete REST API collection for the Urban Traffic Management System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwt_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000"
    },
    {
      "key": "auth_url",
      "value": "http://localhost:3001"
    },
    {
      "key": "vehicles_url",
      "value": "http://localhost:3002"
    },
    {
      "key": "traffic_url",
      "value": "http://localhost:3003"
    },
    {
      "key": "incidents_url",
      "value": "http://localhost:3004"
    },
    {
      "key": "notifications_url",
      "value": "http://localhost:3005"
    },
    {
      "key": "jwt_token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\\n  \\\"email\\\": \\\"newuser@traffic.com\\\",\\n  \\\"password\\\": \\\"SecurePass123!\\\",\\n  \\\"firstName\\\": \\\"John\\\",\\n  \\\"lastName\\\": \\\"Doe\\\"\\n}"
            },
            "url": {
              "raw": "{{auth_url}}/auth/register",
              "host": ["{{auth_url}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\\n  \\\"email\\\": \\\"operator@traffic.com\\\",\\n  \\\"password\\\": \\\"password123\\\"\\n}"
            },
            "url": {
              "raw": "{{auth_url}}/auth/login",
              "host": ["{{auth_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Validate Token",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{auth_url}}/auth/validate",
              "host": ["{{auth_url}}"],
              "path": ["auth", "validate"]
            }
          }
        }
      ]
    },
    {
      "name": "Vehicles",
      "item": [
        {
          "name": "Create Vehicle",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\\n  \\\"plateNumber\\\": \\\"NEW-2024\\\",\\n  \\\"brand\\\": \\\"Tesla\\\",\\n  \\\"model\\\": \\\"Model 3\\\",\\n  \\\"type\\\": \\\"ELECTRIC_CAR\\\"\\n}"
            },
            "url": {
              "raw": "{{vehicles_url}}/vehicles",
              "host": ["{{vehicles_url}}"],
              "path": ["vehicles"]
            }
          }
        },
        {
          "name": "Get All Vehicles",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{vehicles_url}}/vehicles",
              "host": ["{{vehicles_url}}"],
              "path": ["vehicles"]
            }
          }
        },
        {
          "name": "Get Vehicle by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{vehicles_url}}/vehicles/{{vehicle_id}}",
              "host": ["{{vehicles_url}}"],
              "path": ["vehicles", "{{vehicle_id}}"]
            }
          }
        },
        {
          "name": "Record GPS Position",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\\n  \\\"latitude\\\": 48.8566,\\n  \\\"longitude\\\": 2.3522,\\n  \\\"speed\\\": 45.5,\\n  \\\"heading\\\": 270\\n}"
            },
            "url": {
              "raw": "{{vehicles_url}}/vehicles/{{vehicle_id}}/gps",
              "host": ["{{vehicles_url}}"],
              "path": ["vehicles", "{{vehicle_id}}", "gps"]
            }
          }
        },
        {
          "name": "Get Vehicle History",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{vehicles_url}}/vehicles/{{vehicle_id}}/history",
              "host": ["{{vehicles_url}}"],
              "path": ["vehicles", "{{vehicle_id}}", "history"]
            }
          }
        },
        {
          "name": "Update Vehicle Status",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\\n  \\\"status\\\": \\\"MAINTENANCE\\\"\\n}"
            },
            "url": {
              "raw": "{{vehicles_url}}/vehicles/{{vehicle_id}}/status",
              "host": ["{{vehicles_url}}"],
              "path": ["vehicles", "{{vehicle_id}}", "status"]
            }
          }
        },
        {
          "name": "Delete Vehicle",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{vehicles_url}}/vehicles/{{vehicle_id}}",
              "host": ["{{vehicles_url}}"],
              "path": ["vehicles", "{{vehicle_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Traffic Management",
      "item": [
        {
          "name": "Create Traffic Zone",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
