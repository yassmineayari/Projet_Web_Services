            "body": {
              "mode": "raw",
              "raw": "{\\n  \\\"name\\\": \\\"Downtown Core\\\",\\n  \\\"description\\\": \\\"Central business district\\\",\\n  \\\"centerLatitude\\\": 48.8566,\\n  \\\"centerLongitude\\\": 2.3522,\\n  \\\"radiusKm\\\": 2.5\\n}"
            },
            "url": {
              "raw": "{{traffic_url}}/traffic/zones",
              "host": ["{{traffic_url}}"],
              "path": ["traffic", "zones"]
