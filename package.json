{
  "name": "urban-traffic-management",
  "version": "1.0.0",
  "description": "Distributed urban traffic management system with GraphQL API Gateway",
  "author": "Your Team",
  "license": "MIT",
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "build": "nest build",
    "start:gateway": "nest start --config nest-cli.json",
    "start:auth": "ts-node -r tsconfig-paths/register src/auth-main.ts",
    "start:vehicles": "ts-node -r tsconfig-paths/register src/vehicles-main.ts",
    "start:traffic": "ts-node -r tsconfig-paths/register src/traffic-main.ts",
    "start:incidents": "ts-node -r tsconfig-paths/register src/incidents-main.ts",
    "start:notifications": "ts-node -r tsconfig-paths/register src/notifications-main.ts",
    "start:all": "concurrently \"npm run start:gateway\" \"npm run start:auth\" \"npm run start:vehicles\" \"npm run start:traffic\" \"npm run start:incidents\" \"npm run start:notifications\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\""
  },
  "dependencies": {
    "@apollo/server": "^4.9.7",
    "@nestjs/apollo": "^12.0.0",
    "@nestjs/axios": "^3.0.0",
    "@nestjs/common": "^10.2.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.2.0",
    "@nestjs/graphql": "^12.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.2.0",
    "@prisma/client": "^6.19.3",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "graphql": "^16.8.0",
    "graphql-subscriptions": "^2.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.0",
    "prisma": "^6.19.3",
    "reflect-metadata": "^0.1.13",
    "rimraf": "^5.0.0",
    "rxjs": "^7.8.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.2.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.2.0",
    "@types/express": "^4.17.20",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.4.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "concurrently": "^8.2.0",
    "eslint": "^8.45.0",
    "jest": "^29.6.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.0"
  }
}
